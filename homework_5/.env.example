# Copy to .env and fill in ANTHROPIC_API_KEY. Other values have safe defaults.

# Required: Anthropic API key (used by the agents AND the LLM-as-Judge guardrail)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Models
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929        # used by llm.py (the LLM-Judge guardrail)
LLM_PROVIDER=anthropic                             # used by skillab.get_llm() inside the L6 agents
LLM_MODEL=claude-sonnet-4-5-20250929               # model name passed to skillab

# PostgreSQL — used by the RAG agent (Orchestrator's worker uses pgvector)
DATABASE_URL=postgresql://skillab:skillab_dev@localhost:5432/skillab
POSTGRES_DB=skillab
POSTGRES_USER=skillab
POSTGRES_PASSWORD=skillab_dev
