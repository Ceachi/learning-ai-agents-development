# Copy this file to `.env` and fill in your keys.
# `.env` is gitignored — never commit real keys.

# LLM Provider Keys (choose one — set DEFAULT_PROVIDER below to match)
# ===================================================================

# Ollama (local, free) - no API key needed
OLLAMA_BASE_URL=http://localhost:11434

# Google Gemini (free tier)
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI (paid)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude (paid)
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# Observability
# ===================================================================

# LangSmith (recommended)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_your_langsmith_key_here
LANGCHAIN_PROJECT=homework-2-qa-agent

# LangFuse (open-source alternative)
# LANGFUSE_PUBLIC_KEY=pk-xxx
# LANGFUSE_SECRET_KEY=sk-xxx
# LANGFUSE_HOST=http://localhost:3000


# Settings
# ===================================================================
# Free local option: set DEFAULT_PROVIDER=ollama and DEFAULT_MODEL=llama3.2
# (note: small local models handle tool calling less reliably than Claude).
DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-6


# PostgreSQL + pgvector (document storage & RAG)
# ===================================================================
# docker-compose reads POSTGRES_*; the app/Alembic read DATABASE_URL.
# Port 5433 on the host avoids clashing with a local Postgres on 5432.
POSTGRES_USER=analyst
POSTGRES_PASSWORD=analyst123
POSTGRES_DB=document_analyst
DATABASE_URL=postgresql://analyst:analyst123@localhost:5433/document_analyst
# SQL echo for debugging (default off)
SQL_ECHO=false
